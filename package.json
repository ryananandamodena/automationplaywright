{
  "name": "playwright-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for Playwright - Control browsers through AI assistants",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "playwright-mcp-server": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "start": "node build/index.js",
    "dev": "tsc --watch"
  },
  "keywords": [
    "mcp",
    "playwright",
    "browser",
    "automation",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^17.3.1",
    "playwright": "^1.40.0",
    "puppeteer": "^24.40.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
