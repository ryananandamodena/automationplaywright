# =========================================
# MHC Automation - Konfigurasi Email (SMTP)
# =========================================
# Salin file ini menjadi .env dan isi nilai yang sesuai

# SMTP Server (default: Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Akun pengirim email
# Untuk Gmail: gunakan App Password (bukan password biasa)
# Cara buat App Password: Google Account → Security → 2-Step Verification → App Passwords
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Email pengirim (opsional, default = SMTP_USER)
EMAIL_FROM=MHC Automation <your-email@gmail.com>

# Email tujuan laporan bug
EMAIL_TO=ryan.ananda@modena.com
